{
  "$schema": "https://phoenix.local/gnap/agent.schema.json",
  "$description": "GNAP Agent registration — 每个参与协调的 Agent 维护一个注册文件",
  "template": {
    "agent_id": "string (required) — unique kebab-case identifier",
    "name": "string (required) — human-readable name",
    "type": "string (required) — orchestrator | specialist | worker | observer",
    "capabilities": ["array of strings — what this agent can do"],
    "max_concurrent_tasks": "integer — max simultaneous tasks, default 2",
    "status": "string — idle | busy | offline | error",
    "registered_at": "string — ISO8601 timestamp of registration",
    "last_heartbeat": "string — ISO8601 timestamp of last heartbeat",
    "metadata": {
      "version": "string — agent version",
      "model": "string — underlying model name",
      "host": "string — machine hostname"
    }
  },
  "example": {
    "agent_id": "code-reviewer",
    "name": "Code Reviewer",
    "type": "specialist",
    "capabilities": ["code-review", "security-check", "style-lint", "coverage-check"],
    "max_concurrent_tasks": 2,
    "status": "idle",
    "registered_at": "2026-06-17T00:00:00Z",
    "last_heartbeat": "2026-06-17T00:05:00Z",
    "metadata": {
      "version": "1.0.0",
      "model": "mimo-v2.5-pro",
      "host": "holyty-mac"
    }
  }
}
