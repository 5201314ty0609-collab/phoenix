{
  "_version": "2.0.0",
  "_upgraded_from": "v1.0.0 (7 static regex rules)",
  "_upgraded_to": "v2.0.0 (6 error categories + 9 recovery strategies + confidence scoring)",
  "_source": "Absorbed from MUNDO Agent v2.2.3 intelligent_recovery.py (LiHongwei-cn)",
  "_module": "intelligent_recovery.py",

  "categories": {
    "transient": {
      "description": "瞬时错误（超时、限流、503）",
      "default_strategy": "retry_backoff",
      "escalation_threshold": 5,
      "examples": ["timeout", "429 rate limit", "503 service unavailable"]
    },
    "resource": {
      "description": "资源不足（内存、token、配额）",
      "default_strategy": "compress_context",
      "escalation_threshold": 3,
      "examples": ["out of memory", "quota exceeded", "token limit"]
    },
    "permission": {
      "description": "权限不足（401/403）",
      "default_strategy": "ask_user",
      "escalation_threshold": 1,
      "examples": ["401 unauthorized", "403 forbidden", "EACCES"]
    },
    "network": {
      "description": "网络问题（DNS、连接中断）",
      "default_strategy": "switch_endpoint",
      "escalation_threshold": 3,
      "examples": ["connection refused", "DNS resolution", "broken pipe"]
    },
    "logic": {
      "description": "逻辑错误（工具失败、参数错误）",
      "default_strategy": "switch_tool",
      "escalation_threshold": 3,
      "examples": ["file not found", "type error", "invalid argument"]
    },
    "context": {
      "description": "上下文溢出",
      "default_strategy": "compress_context",
      "escalation_threshold": 2,
      "examples": ["context window exceeded", "prompt too long"]
    }
  },

  "strategies": {
    "retry_immediate": {"description": "立即重试", "cost": "low", "success_rate_estimate": 0.6},
    "retry_backoff": {"description": "指数退避重试+抖动", "cost": "medium", "success_rate_estimate": 0.8},
    "retry_variation": {"description": "改变参数重试", "cost": "medium", "success_rate_estimate": 0.5},
    "switch_endpoint": {"description": "切换API端点", "cost": "low", "success_rate_estimate": 0.7},
    "switch_model": {"description": "切换模型（鲤鱼特有）", "cost": "high", "success_rate_estimate": 0.9},
    "compress_context": {"description": "压缩上下文", "cost": "medium", "success_rate_estimate": 0.85},
    "degrade_quality": {"description": "降级质量", "cost": "medium", "success_rate_estimate": 0.7},
    "ask_user": {"description": "询问用户", "cost": "high", "success_rate_estimate": 1.0},
    "switch_tool": {"description": "切换工具", "cost": "medium", "success_rate_estimate": 0.6},
    "abort": {"description": "中止任务", "cost": "terminal", "success_rate_estimate": 0.0}
  },

  "circuit_breaker": {
    "enabled": true,
    "default_failure_threshold": 5,
    "default_recovery_timeout_seconds": 60,
    "default_half_open_max": 2
  },

  "nociception_integration": {
    "cascade_window_minutes": 5,
    "healthy_threshold": 2,
    "warning_threshold": 4,
    "critical_threshold": 5
  }
}
