# =============================================================================
# PHOENIX AIOS 环境变量配置 — 生产环境
# =============================================================================
# 使用说明:
#   1. 复制此文件为 .env
#   2. 修改所有敏感信息（密码、密钥等）
#   3. 确保所有必需变量已设置
# =============================================================================

# ── PHOENIX Core 配置 ─────────────────────────────────────────────────────
PHOENIX_PORT=8765
PHOENIX_HOST=0.0.0.0
PHOENIX_ENV=production
PHOENIX_VERSION=1.3.0
PHOENIX_LOG_LEVEL=INFO
PHOENIX_DEBUG=false

# ── Redis 配置 ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=phoenix_redis_pass
REDIS_URL=redis://redis:6379/0
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# ── Nginx 配置 ────────────────────────────────────────────────────────────
NGINX_HOST=phoenix.local
NGINX_SSL_ENABLED=true
NGINX_SSL_CERT=/etc/nginx/ssl/phoenix.crt
NGINX_SSL_KEY=/etc/nginx/ssl/phoenix.key

# ── 监控配置 ──────────────────────────────────────────────────────────────
PROMETHEUS_RETENTION=30d
PROMETHEUS_SCRAPE_INTERVAL=15s
GRAFANA_USER=admin
GRAFANA_PASSWORD=phoenix_grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_ALLOW_SIGN_UP=false
LOKI_RETENTION=30d

# ── Sentry 错误监控 ──────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── 安全配置 ──────────────────────────────────────────────────────────────
# JWT 密钥（用于 API 认证）
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# API 密钥（用于内部服务通信）
API_KEY=your_api_key_here

# CORS 配置
CORS_ORIGINS=https://phoenix.local,https://your-domain.com
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-Request-ID

# ── 限流配置 ──────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_BURST=20

# ── 日志配置 ──────────────────────────────────────────────────────────────
LOG_FORMAT=json
LOG_FILE=/opt/phoenix/logs/phoenix.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3
LOG_ROTATION=daily

# ── 备份配置 ──────────────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION=30
BACKUP_PATH=/opt/phoenix/backups

# ── 健康检查配置 ──────────────────────────────────────────────────────────
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=10s

# ── 资源限制 ──────────────────────────────────────────────────────────────
PHOENIX_CPU_LIMIT=2.0
PHOENIX_MEMORY_LIMIT=2G
PHOENIX_CPU_RESERVATION=0.5
PHOENIX_MEMORY_RESERVATION=512M
