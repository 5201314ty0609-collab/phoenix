# =============================================================================
# PHOENIX AIOS 部署目录 .gitignore
# =============================================================================

# 环境变量文件（包含敏感信息）
.env
*.env.local
*.env.production

# SSL 证书
nginx/ssl/*.crt
nginx/ssl/*.key
nginx/ssl/*.pem

# 备份文件
backups/
*.tar.gz
*.bak

# 日志文件
logs/
*.log

# 临时文件
tmp/
temp/
*.tmp
*.temp

# Docker 数据卷
data/
redis-data/
prometheus-data/
grafana-data/
loki-data/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# 操作系统文件
.DS_Store
Thumbs.db

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 虚拟环境
venv/
.venv/
env/

# 测试覆盖率
htmlcov/
.coverage
coverage.xml

# 文档构建
docs/_build/
