<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<title>PHOENIX · Live Monitor</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js">
</script>
<style>
:root{
  --bg:#08080e;--surface:#111119;--surface-alt:#181824;--border:#222228;
  --text:#e4e0db;--text-dim:#6b6560;--accent:#f49e42;--accent-glow:rgba(244,158,66,0.2);
  --accent2:#7aa2f7;--red:#e05555;--green:#4caf50;--yellow:#f0a040;--purple:#bb9af7;
  --radius:10px;--radius-lg:14px;--gap:12px;
  --font:system-ui,-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',sans-serif;
  --mono:'SF Mono','Cascadia Code','Fira Code',monospace;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:var(--font);background:var(--bg);color:var(--text);padding:14px 16px;line-height:1.5}
.header{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;background:var(--surface);border-radius:var(--radius);margin-bottom:14px;border:1px solid var(--border)}
.header h1{font-size:1.1rem;font-weight:700}
.header .conn{display:flex;align-items:center;gap:8px;font-size:0.76rem}
.dot{width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0}
.dot.ok{background:var(--green);box-shadow:0 0 6px var(--green)}
.dot.warn{background:var(--yellow);animation:pulse 2s infinite}
.dot.err{background:var(--red)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.25}}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--gap);margin-bottom:14px}
.stat-card{background:var(--surface);border-radius:var(--radius);padding:14px 16px;text-align:center;border:1px solid var(--border)}
.stat-card .num{font-size:1.8rem;font-weight:800;line-height:1.1}
.stat-card .num.c-accent{color:var(--accent)}.stat-card .num.c-green{color:var(--green)}.stat-card .num.c-red{color:var(--red)}.stat-card .num.c-yellow{color:var(--yellow)}.stat-card .num.c-purple{color:var(--purple)}
.stat-card .label{font-size:0.7rem;color:var(--text-dim);margin-top:4px}
.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:var(--gap);margin-bottom:14px}
.grid-3{grid-template-columns:repeat(3,1fr)}
.card{background:var(--surface);border-radius:var(--radius);padding:14px 16px;border:1px solid var(--border);transition:border-color .15s}
.card:hover{border-color:rgba(244,158,66,.2)}
.card h3{font-size:0.75rem;color:var(--accent);margin-bottom:10px;display:flex;justify-content:space-between;align-items:center}
.card h3 .badge{font-size:0.62rem;padding:2px 8px;border-radius:8px;background:rgba(122,162,247,.12);color:var(--accent2)}
.chart-wrap{position:relative;width:100%;height:220px}.chart-wrap.sm{height:170px}
.sense-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
.sense-item{background:var(--surface-alt);border-radius:8px;padding:10px;text-align:center}
.sense-item .icon{font-size:1.3rem;margin-bottom:3px}
.sense-item .name{font-size:0.65rem;color:var(--text-dim)}
.sense-item .bar{margin-top:6px;height:3px;border-radius:3px;background:var(--border);overflow:hidden}
.sense-item .bar-fill{height:100%;border-radius:3px;transition:width .5s ease}
.sense-item .val{font-size:0.68rem;font-weight:600;margin-top:4px}
.fill-g{background:var(--green)}.fill-y{background:var(--yellow)}.fill-r{background:var(--red)}.fill-a{background:var(--accent)}
.tbl{overflow-x:auto;max-height:240px;overflow-y:auto}
table{width:100%;border-collapse:collapse;font-size:0.75rem}
th,td{padding:7px 10px;text-align:left;border-bottom:1px solid var(--border)}
th{color:var(--accent);font-weight:600;font-size:0.68rem;text-transform:uppercase;letter-spacing:.04em;position:sticky;top:0;background:var(--surface)}
tr:hover{background:rgba(255,255,255,.015)}
.module-list{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;font-size:0.72rem}
.module-item{display:flex;align-items:center;gap:6px;padding:4px 8px;background:var(--surface-alt);border-radius:5px}
.module-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;background:var(--green)}
footer{text-align:center;margin-top:18px;color:var(--text-dim);font-size:0.65rem;padding:8px}
.toast{position:fixed;bottom:16px;right:16px;padding:8px 16px;border-radius:var(--radius);font-size:0.72rem;z-index:200;font-weight:600;animation:slideUp .3s ease}
@keyframes slideUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.toast.ok{background:var(--green);color:var(--bg)}.toast.err{background:var(--red);color:var(--bg)}
@media(max-width:1024px){.grid,.grid-3{grid-template-columns:1fr}.stats{grid-template-columns:repeat(2,1fr)}.sense-grid{grid-template-columns:repeat(2,1fr)}.module-list{grid-template-columns:repeat(2,1fr)}}
@media(max-width:640px){.stats{grid-template-columns:1fr}.module-list{grid-template-columns:1fr}}
</style>
</head>
<body>

<div class="header">
  <h1>PHOENIX 实时监控 <span style="font-weight:400;color:var(--text-dim);font-size:0.65em">/ Live Monitor</span></h1>
  <div style="display:flex;align-items:center;gap:20px">
    <a href="index.html" style="color:var(--text-dim);text-decoration:none;font-size:0.78rem">首页</a>
    <a href="dashboard.html" style="color:var(--text-dim);text-decoration:none;font-size:0.78rem">仪表盘</a>
    <div class="conn">
    <span class="dot warn" id="conn-dot"></span>
    <span id="conn-text" style="font-family:var(--mono);font-size:0.72rem">detecting...</span>
    <span style="color:var(--text-dim);font-size:0.68rem" id="conn-time"></span>
  </div></div>
</div>

<!-- KPI Row 1 -->
<div class="stats">
  <div class="stat-card"><div class="num c-accent" id="kpi-modules">...</div><div class="label">引擎模块 / Engine Modules</div></div>
  <div class="stat-card"><div class="num c-green" id="kpi-rules">...</div><div class="label">规则文件 / Rule Files</div></div>
  <div class="stat-card"><div class="num c-purple" id="kpi-rule-health">...</div><div class="label">规则健康 / Rule Health</div></div>
  <div class="stat-card"><div class="num c-yellow" id="kpi-cost-health">...</div><div class="label">成本健康 / Cost Health</div></div>
</div>

<!-- KPI Row 2 -->
<div class="stats">
  <div class="stat-card"><div class="num c-accent" id="kpi-tools">...</div><div class="label">工具调用 / Tool Calls</div></div>
  <div class="stat-card"><div class="num c-green" id="kpi-frameworks">...</div><div class="label">活跃框架 / Active Frameworks</div></div>
  <div class="stat-card"><div class="num c-red" id="kpi-blocked">...</div><div class="label">阻断次数 / Blocked</div></div>
  <div class="stat-card"><div class="num c-yellow" id="kpi-hooks">...</div><div class="label">Hook 脚本 / Hooks</div></div>
</div>

<!-- Charts Row 1 -->
<div class="grid">
  <div class="card">
    <h3>工具使用 / Tool Usage <span class="badge" id="badge-tools">Bash 44%</span></h3>
    <div class="chart-wrap"><canvas id="toolChart"></canvas></div>
  </div>
  <div class="card">
    <h3>七感雷达 / 7-Sense Radar</h3>
    <div class="chart-wrap"><canvas id="radarChart"></canvas></div>
  </div>
</div>

<!-- Charts Row 2 -->
<div class="grid grid-3">
  <div class="card">
    <h3>会话活动 / Session Activity</h3>
    <div class="chart-wrap sm"><canvas id="sessionChart"></canvas></div>
  </div>
  <div class="card">
    <h3>错误率趋势 / Error Rate Trend</h3>
    <div class="chart-wrap sm"><canvas id="errorChart"></canvas></div>
  </div>
  <div class="card">
    <h3>浪费分析 / Waste Breakdown</h3>
    <div class="chart-wrap sm"><canvas id="wasteChart"></canvas></div>
  </div>
</div>

<!-- Seven Sense + Modules -->
<div class="grid">
  <div class="card">
    <h3>七感状态 / 7-Sense Status <span class="badge">全部健康 all healthy</span></h3>
    <div class="sense-grid" id="sense-grid"></div>
  </div>
  <div class="card">
    <h3>核心模块 / Core Modules <span class="badge" id="badge-modules">加载中...</span></h3>
    <div class="module-list" id="module-list"></div>
  </div>
</div>

<!-- Timeline -->
<div class="card" style="margin-bottom:14px">
  <h3>最近活动 / Recent Activity <span class="badge" id="badge-timeline">7 条 / events</span></h3>
  <div class="tbl">
    <table><thead><tr><th>时间 / Time</th><th>类型 / Type</th><th>描述 / Description</th></tr></thead>
    <tbody id="timeline-body"></tbody></table>
  </div>
</div>

<footer>PHOENIX v1.3.0 · <span id="footer-mode">GitHub Pages</span> · 自动刷新 / Auto-refresh: <span id="footer-refresh">30s</span></footer>
<div id="toast" style="display:none"></div>

<script>
// ═══════════════════════════════════════════════
// FALLBACK — only used when server is unreachable
// ═══════════════════════════════════════════════
const FALLBACK = {
  "modules": 27,
  "rules": 15,
  "senses": 7,
  "rule_health": 93,
  "cost_health": 72,
  "cost_grade": "C",
  "toolCalls": 2026,
  "blocked": 33,
  "frameworks_active": 26,
  "hooks": 9
},
  wasteBreakdown:{ghost_skills:62,repeated_context:0,tool_imbalance:0,blocked_attempts:33,other:14},
  senseStates:[
    {id:'o2',name:'O2 生命力/Vitality',icon:'🫁',val:12,status:'healthy',color:'green'},
    {id:'nociception',name:'痛觉/Nociception',icon:'💢',val:8,status:'healthy',color:'green'},
    {id:'chronos',name:'时间/Chronos',icon:'⏱️',val:5,status:'healthy',color:'green'},
    {id:'spatial',name:'空间/Spatial',icon:'📍',val:15,status:'healthy',color:'green'},
    {id:'vestibular',name:'平衡/Vestibular',icon:'⚖️',val:22,status:'healthy',color:'green'},
    {id:'echo',name:'回响/Echo',icon:'🔁',val:3,status:'healthy',color:'green'},
    {id:'drift',name:'漂移/Drift',icon:'🧭',val:6,status:'healthy',color:'green'}
  ],
  moduleList:['context_mapper','inspector','knowledge-base','phoenix-bash-guard','phoenix-cost-tracker','phoenix-mutation-gate','phoenix-observability','phoenix-auto-memory','phoenix-rule-health','server','tool-guard','reflection-engine','timeline','policy-engine'],
  timeline:[
    {time:'2026-06-17',type:'audit',desc:'v1.3 全面审计修复（10 项）'},
    {time:'2026-06-17',type:'check',desc:'每日基础检查 + ECC 安全评估'}
  ],
  sessionsByDay:{'06-15':4,'06-16':7,'06-17':3},
  errorByDay:{'06-15':2,'06-16':5,'06-17':1}
};
let data = JSON.parse(JSON.stringify(FALLBACK));
let serverConnected = false;
let charts = {};
let refreshTimer = null;
const SERVER = 'http://localhost:8765';

// ═══════════════════════════════════════════════
// CONNECTION DETECTION
// ═══════════════════════════════════════════════
function setConnStatus(state, text){
  const dot=document.getElementById('conn-dot'), txt=document.getElementById('conn-text');
  dot.className='dot '+state; txt.textContent=text;
  serverConnected = (state === 'ok');
  document.getElementById('footer-refresh').textContent = serverConnected ? '10s (实时/live)' : '静态/static';
}
async function tryConnect(){
  setConnStatus('warn','连接中... / connecting');
  try{
    const ctrl=new AbortController(); setTimeout(()=>ctrl.abort(),3000);
    const r=await fetch(SERVER+'/api/stats',{signal:ctrl.signal});
    if(r.ok){ setConnStatus('ok','live @ :8765');
      document.getElementById('conn-time').textContent=new Date().toLocaleTimeString();
      document.getElementById('footer-mode').textContent='Live Server'; return true; }
  }catch(e){}
  setConnStatus('err','离线 / offline — 请启动 server.py'); document.getElementById('footer-mode').textContent='GitHub Pages';
  return false;
}
async function fetchLive(){
  if(!serverConnected) return null;
  try{
    const ctrl=new AbortController(); setTimeout(()=>ctrl.abort(),5000);
    const[stats,status,timeline]=await Promise.all([
      fetch(SERVER+'/api/stats',{signal:ctrl}).then(r=>r.ok?r.json():null).catch(()=>null),
      fetch(SERVER+'/api/status',{signal:ctrl}).then(r=>r.ok?r.json():null).catch(()=>null),
      fetch(SERVER+'/api/timeline?limit=20',{signal:ctrl}).then(r=>r.ok?r.json():null).catch(()=>null)
    ]);
    return {stats,status,timeline};
  }catch(e){}
  return null;
}

// ═══════════════════════════════════════════════
// APPLY LIVE DATA → data object + DOM
// ═══════════════════════════════════════════════
function applyLiveData(live){
  if(!live) return;
  const s = live.stats;
  const st = live.status;
  const tl = live.timeline;

  // KPIs from /api/stats
  if(s){
    data.modules = s.modules || 0;
    data.rules = s.rules || 0;
    data.senses = s.senses || 0;
    data.toolCalls = s.tool_calls || 0;
    data.blocked = s.blocked || 0;
    data.rule_health = s.rule_health || 0;
    data.cost_health = s.cost_health || 0;
    data.cost_grade = s.cost_grade || 'F';
    data.moduleList = s.module_list || [];
    data.frameworks_active = s.frameworks_active || 0;
    data.hooks = s.hooks || 0;
    if(s.tool_usage && Object.keys(s.tool_usage).length > 0){
      data.toolUsage = s.tool_usage;
    }
    if(s.waste && Object.keys(s.waste).length > 0){
      data.wasteBreakdown = s.waste;
    }
  }

  // Senses from /api/status
  if(st?.senses){
    data.senseStates = data.senseStates.map(sx => ({
      ...sx,
      status: st.senses[sx.id]?.state || sx.status
    }));
  }

  // Timeline from /api/timeline
  if(tl?.entries?.length){
    data.timeline = tl.entries.slice(-10).map(e => ({
      time: e.timestamp || e.time || '',
      type: e.type || 'event',
      desc: e.message || e.description || JSON.stringify(e).slice(0, 80)
    }));
  }
}

// ═══════════════════════════════════════════════
// CHARTS
// ═══════════════════════════════════════════════
function destroyCharts(){ Object.values(charts).forEach(c=>c.destroy()); charts={}; }
function buildAllCharts(){
  destroyCharts();
  const opts={responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}}};
  const colors=['#f49e42','#7aa2f7','#4caf50','#e05555','#bb9af7','#7dcfff','#f0a040','#9ece6a','#c0caf5','#565f89'];

  // Tool Usage
  const toolData=data.toolUsage;
  charts.tool=new Chart(document.getElementById('toolChart'),{type:'bar',data:{labels:Object.keys(toolData),datasets:[{data:Object.values(toolData),backgroundColor:colors,borderRadius:4}]},options:{...opts,indexAxis:'y',scales:{x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#6b6560',font:{size:10}}}}}});

  // Radar
  const senseData=data.senseStates;
  charts.radar=new Chart(document.getElementById('radarChart'),{type:'radar',data:{labels:senseData.map(s=>s.name),datasets:[{data:senseData.map(s=>s.val),backgroundColor:'rgba(244,158,66,0.15)',borderColor:'#f49e42',borderWidth:1.5,pointBackgroundColor:'#f49e42',pointRadius:3}]},options:{...opts,scales:{r:{grid:{color:'rgba(255,255,255,0.08)'},ticks:{display:false},suggestedMin:0,suggestedMax:30}}}});

  // Session Activity
  const days=Object.keys(data.sessionsByDay);
  charts.session=new Chart(document.getElementById('sessionChart'),{type:'line',data:{labels:days,datasets:[{data:Object.values(data.sessionsByDay),borderColor:'#f49e42',backgroundColor:'rgba(244,158,66,0.1)',fill:true,tension:.4,pointRadius:4}]},options:{...opts,scales:{y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#6b6560',font:{size:10}}},x:{ticks:{color:'#6b6560',font:{size:10}}}}}});

  // Error Rate
  charts.error=new Chart(document.getElementById('errorChart'),{type:'line',data:{labels:Object.keys(data.errorByDay),datasets:[{data:Object.values(data.errorByDay),borderColor:'#e05555',backgroundColor:'rgba(224,85,85,0.1)',fill:true,tension:.4,pointRadius:4}]},options:{...opts,scales:{y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#6b6560',font:{size:10}}},x:{ticks:{color:'#6b6560',font:{size:10}}}}}});

  // Waste Breakdown
  const waste=data.wasteBreakdown;
  charts.waste=new Chart(document.getElementById('wasteChart'),{type:'doughnut',data:{labels:Object.keys(waste),datasets:[{data:Object.values(waste),backgroundColor:['#e05555','#f0a040','#7aa2f7','#bb9af7','#565f89'],borderWidth:0}]},options:{...opts,plugins:{legend:{position:'right',labels:{color:'#8a8580',font:{size:10},padding:12}}}}});
}

// ═══════════════════════════════════════════════
// UI BUILDERS
// ═══════════════════════════════════════════════
function buildSenses(){
  const grid=document.getElementById('sense-grid');
  grid.innerHTML=data.senseStates.map(s=>{
    const c=s.color==='green'?'g':s.color==='yellow'?'y':'r';
    return `<div class="sense-item"><div class="icon">${s.icon}</div><div class="name">${s.name}</div><div class="bar"><div class="bar-fill fill-${c}" style="width:${s.val}%"></div></div><div class="val" style="color:var(--${s.color==='green'?'green':'yellow'})">${s.status}</div></div>`;
  }).join('');
}
function buildModules(){
  document.getElementById('module-list').innerHTML=data.moduleList.map(m=>`<div class="module-item"><span class="module-dot"></span>${m}.py</div>`).join('');
  document.getElementById('badge-modules').textContent=data.moduleList.length+' 个 / total';
}
function buildTimeline(){
  document.getElementById('timeline-body').innerHTML=data.timeline.map(t=>`<tr><td style="font-family:var(--mono);font-size:0.7rem;color:var(--text-dim)">${t.time.slice(-8)}</td><td style="font-size:0.68rem">${t.type}</td><td>${t.desc}</td></tr>`).join('');
  document.getElementById('badge-timeline').textContent=data.timeline.length+' events';
}
function buildKPIs(){
  document.getElementById('kpi-modules').textContent=data.modules;
  document.getElementById('kpi-rules').textContent=data.rules;
  document.getElementById('kpi-rule-health').textContent=data.rule_health+'%';
  document.getElementById('kpi-cost-health').textContent=data.cost_health+' ('+data.cost_grade+'级)';
  document.getElementById('kpi-tools').textContent=data.toolCalls.toLocaleString();
  document.getElementById('kpi-blocked').textContent=data.blocked;
  if(data.frameworks_active !== undefined) document.getElementById('kpi-frameworks').textContent=data.frameworks_active;
  if(data.hooks !== undefined) document.getElementById('kpi-hooks').textContent=data.hooks;
}
function toast(msg,ok){ const t=document.getElementById('toast');t.textContent=msg;t.className='toast '+(ok?'ok':'err');t.style.display='block';setTimeout(()=>t.style.display='none',2500); }

// ═══════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════
async function init(){
  // Fetch real data FIRST, then render
  try{
    const ctrl=new AbortController(); setTimeout(()=>ctrl.abort(),3000);
    const r=await fetch(SERVER+'/api/stats',{signal:ctrl.signal});
    if(r.ok){
      const s=await r.json();
      data.modules=s.modules||0; data.rules=s.rules||0; data.senses=s.senses||0;
      data.toolCalls=s.tool_calls||0; data.blocked=s.blocked||0;
      data.rule_health=s.rule_health||0; data.cost_health=s.cost_health||0; data.cost_grade=s.cost_grade||'F';
      data.frameworks_active=s.frameworks_active||0; data.hooks=s.hooks||0;
      if(s.tool_usage) data.toolUsage=s.tool_usage;
      if(s.waste) data.wasteBreakdown=s.waste;
      if(s.module_list) data.moduleList=s.module_list;
      setConnStatus('ok','live @ :8765');
      document.getElementById('footer-mode').textContent='Live Server';
      serverConnected=true;
    }else{ setConnStatus('err','离线 / offline'); }
  }catch(e){ setConnStatus('err','离线 / offline'); }
  // Fetch activity from API
  try{
    const ctrl2=new AbortController(); setTimeout(()=>ctrl2.abort(),3000);
    const r2=await fetch(SERVER+'/api/activity',{signal:ctrl2.signal});
    if(r2.ok){
      const a=await r2.json();
      if(a.entries && a.entries.length>0){
        data.timeline=a.entries.slice(0,10).map(e=>({time:e.time,type:e.type,desc:e.desc}));
      }
    }
  }catch(e){}
  // Render with whatever data we have
  buildSenses(); buildModules(); buildTimeline(); buildKPIs(); buildAllCharts();
  if(serverConnected) toast('已连接 PHOENIX 服务器 / Connected','ok');
  refreshTimer=setInterval(refresh, serverConnected?10000:30000);
}
async function refresh(){
  if(!serverConnected){ await tryConnect(); return; }
  try{
    const ctrl=new AbortController(); setTimeout(()=>ctrl.abort(),5000);
    const r=await fetch(SERVER+'/api/stats',{signal:ctrl.signal});
    if(!r.ok) throw new Error('not ok');
    const s=await r.json();
    // Direct DOM update — same pattern as dashboard.html
    data.modules=s.modules||0; data.rules=s.rules||0; data.senses=s.senses||0;
    data.toolCalls=s.tool_calls||0; data.blocked=s.blocked||0;
    data.rule_health=s.rule_health||0; data.cost_health=s.cost_health||0; data.cost_grade=s.cost_grade||'F';
    data.frameworks_active=s.frameworks_active||0; data.hooks=s.hooks||0;
    if(s.tool_usage) data.toolUsage=s.tool_usage;
    if(s.waste) data.wasteBreakdown=s.waste;
    if(s.module_list) data.moduleList=s.module_list;
    // Fetch activity
    try{
      const ctrl2=new AbortController(); setTimeout(()=>ctrl2.abort(),3000);
      const r2=await fetch(SERVER+'/api/activity',{signal:ctrl2.signal});
      if(r2.ok){
        const a=await r2.json();
        if(a.entries && a.entries.length>0){
          data.timeline=a.entries.slice(0,10).map(e=>({time:e.time,type:e.type,desc:e.desc}));
        }
      }
    }catch(e2){}
    // Update DOM
    buildKPIs(); buildModules(); buildTimeline(); buildAllCharts();
    setConnStatus('ok','实时 / live @ :8765');
    document.getElementById('conn-time').textContent=new Date().toLocaleTimeString();
  }catch(e){
    setConnStatus('warn','重连中... / reconnecting');serverConnected=false;
  }
}
init();
</script>
</body>
</html>
